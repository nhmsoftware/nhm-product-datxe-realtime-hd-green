# Cấu hình máy chủ
# Máy chủ và cổng máy chủ thời gian thực sẽ chạy trên
HOST=0.0.0.0
PORT=3002

# Redis Configuration Cấu hình Redis
# Yêu cầu để nhận Pub/Sub để nhận sự kiện
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis Channels Cấu hình kênh Redis
# Các Kênh cụ thể để nhận các sự kiện khác nhau
REDIS_CHANNEL=ride.tracking.events
REDIS_COMMUNICATION_CHANNEL=ride.communication.events

# Security & CORS Cấu hình an toàn & CORS
# Cho phép truy cập từ các domain khác (danh sách ngăn cách bằng dấu phẩy)
# Domain được phép kết nối với máy chủ thời gian thực qua Socket.io
CORS_ORIGINS=*

# Tracking & Stale Detection Cấu hình theo dõi & phát hiện sự kiện cũ
# Thời gian sau khi sự kiện được coi là sự kiện stale
LOCATION_STALE_AFTER_MS=45000
# Thời gian kiểm tra sự kiện cũ
STALE_SWEEP_INTERVAL_MS=15000

# Mock / Demo Configuration (Optional)
# Nếu chạy các scrip simulation thì sử dụng cấu hình này
# URL máy chủ backend của Laravel để nhận các sự kiện từ Redis
BACKEND_URL=http://api.nhm-datxe.local
RIDE_ID=your_mock_ride_id
DRIVER_TOKEN=your_mock_driver_token
STREAM_INTERVAL_MS=3000
DRIVER_ROUTE=[]
CANCEL_REASON=
